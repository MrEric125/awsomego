# Eino AI Framework Configuration

# OpenAI 配置（Eino 和 LangChain 共用）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=qwen2.5-coder:7b
OPENAI_BASE_URL=http://localhost:11434/api
# ollama,openai,ark
MODEL_TYPE=ollama
# 通用 AI 配置（Eino）
AI_TIMEOUT=30
AI_MAX_RETRIES=3
AI_TEMPERATURE=0.7
AI_TOP_P=0.9
AI_MAX_TOKENS=2000

# ============================================
# LangChain Configuration
# ============================================

# LangChain 通用配置
LC_TEMPERATURE=0.7
LC_TOP_P=0.9
LC_MAX_TOKENS=2000
LC_TIMEOUT=30
LC_MAX_RETRIES=3
LC_DEFAULT_PROVIDER=openai  # openai, azure, anthropic, google, ollama, deepseek
