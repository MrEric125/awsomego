# Eino AI Framework Configuration

# OpenAI 配置（Eino 和 LangChain 共用）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=qwen2.5-coder:7b
OPENAI_BASE_URL=http://localhost:11434/api
# ollama,openai,ark
MODEL_TYPE=ollama
# 通用 AI 配置（Eino）
AI_TIMEOUT=30
AI_MAX_RETRIES=3
AI_TEMPERATURE=0.7
AI_TOP_P=0.9
AI_MAX_TOKENS=2000

# ============================================
# LangChain Configuration
# ============================================

# LangChain 通用配置
LC_TEMPERATURE=0.7
LC_TOP_P=0.9
LC_MAX_TOKENS=2000
LC_TIMEOUT=30
LC_MAX_RETRIES=3
LC_DEFAULT_PROVIDER=openai  # openai, azure, anthropic, google, ollama, deepseek

# Azure OpenAI 配置（可选）
AZURE_OPENAI_API_KEY=your_azure_api_key
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=gpt-35-turbo
AZURE_OPENAI_API_VERSION=2023-05-15

# Anthropic Claude 配置（可选）
ANTHROPIC_API_KEY=your_anthropic_api_key
ANTHROPIC_MODEL=claude-3-sonnet-20240229

# Google Gemini 配置（可选）
GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL=gemini-pro

# Ollama 配置（本地模型，可选）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama2

# DeepSeek 配置（可选，高性价比）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_URL=https://api.deepseek.com/v1
